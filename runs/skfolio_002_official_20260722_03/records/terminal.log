import numpy as np
# Does the module's own correlation() (np.cov with aweights) center on the WEIGHTED mean?
r = np.array([0.01, -0.02, 0.03, -0.01, 0.02])
w = np.array([0.4, 0.3, 0.2, 0.05, 0.05]); w = w/w.sum()
X = np.column_stack([r, r*0+r])  # 2 identical cols
cov = np.cov(X, rowvar=False, aweights=w)
print('np.cov aweights biased? diag =', np.diag(cov))
# np.cov default ddof: with aweights, ddof=1 -> unbiased. Force biased:
cov_b = np.cov(X, rowvar=False, aweights=w, ddof=0)
print('np.cov aweights ddof=0 diag =', np.diag(cov_b))
# weighted-mean-centered biased variance:
print('weighted-center biased      =', w @ (r - w@r)**2)
# unweighted-mean-centered biased  :
print('unweighted-center biased    =', w @ (r - r.mean())**2)
"
