1	"""
2	公开复现测试: variance 传入非均匀 sample_weight 时的行为。
3	
4	现象: 给定一组非均匀权重, variance(returns, sample_weight=w, biased=True)
5	的返回值与按加权方差参考定义独立计算出的结果不一致。修复前本测试失败。
6	"""
7	import numpy as np
8	from skfolio.measures import variance
9	
10	
11	def test_weighted_variance_matches_reference():
12	    r = np.array([0.01, -0.02, 0.03, -0.01, 0.02])
13	    w = np.array([0.4, 0.3, 0.2, 0.05, 0.05])
14	    w = w / w.sum()
15	
16	    got = variance(r, sample_weight=w, biased=True)
17	
18	    # 加权(有偏)方差的参考值, 独立于被测实现
19	    ref_center = np.sum(w * r)
20	    expected = np.sum(w * (r - ref_center) ** 2)
21	
22	    assert np.isclose(got, expected), (
23	        f"weighted variance result mismatch: got={got}, expected={expected}"
24	    )
